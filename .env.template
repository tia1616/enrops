# Enrops environment variables
# Copy this file to .env and fill in real values before running `npm run dev` or `npm run build`.
# Never commit the real .env — it's in .gitignore.

# ============================================
# FRONTEND (Vite) — exposed to browser
# ============================================
# These are required locally to run the React app.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE


# ============================================
# EDGE FUNCTIONS — set in Supabase Dashboard
# ============================================
# These are NOT set locally. They live in:
#   Supabase Dashboard → Edge Functions → Secrets
# Listed here for documentation only.
#
# Custom secrets (you set these):
#   STRIPE_SECRET_KEY           — Stripe API secret key
#   STRIPE_WEBHOOK_SECRET       — Stripe webhook signing secret
#   RESEND_API_KEY              — Resend API key for transactional email
#   RESEND_FROM_EMAIL           — Verified sender (updates.journeytosteam.com)
#
# Default secrets (Supabase auto-injects these):
#   SUPABASE_URL, SUPABASE_DB_URL, SUPABASE_PUBLISHABLE_KEYS,
#   SUPABASE_SECRET_KEYS, SUPABASE_JWKS
#   (Legacy: SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY)